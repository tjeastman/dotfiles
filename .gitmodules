[submodule "zsh/contrib/oh-my-zsh"]
	path = zsh/contrib/oh-my-zsh
	url = https://github.com/ohmyzsh/ohmyzsh.git
[submodule "zsh/contrib/zsh-completions"]
	path = zsh/contrib/zsh-completions
	url = https://github.com/zsh-users/zsh-completions.git
[submodule "zsh/contrib/zsh-autosuggestions"]
	path = zsh/contrib/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions.git
[submodule "javascript/contrib/nvm"]
	path = javascript/contrib/nvm
	url = https://github.com/nvm-sh/nvm.git
